  "paths": {
    "/v1/network/status": {
      "get": {
        "tags": [
          "Network"
        ],
        "summary": "Network Status",
        "description": "Returns current network status including online player count.",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Network status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerStatusResponse"
                }
              }
            }
          }
        },
        "deprecated": false,
        "security": []
      }
    },
    "/v1/player/{username}": {
      "get": {
        "tags": [
          "Players"
        ],
        "summary": "Player",
        "description": "Retrieves basic profile information for a player by their username.",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "description": "Minecraft username (3-16 characters, alphanumeric and underscore only)",
            "required": true,
            "deprecated": false,
            "allowEmptyValue": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Player found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Player"
                }
              }
            }
          },
          "400": {
            "description": "Invalid username format"
          },
          "404": {
            "description": "Player not found"
          }
        },
        "deprecated": false,
        "security": []
      }
    },
    "/v1/skyblock/bazaar/items": {
      "get": {
        "tags": [
          "SkyBlock Bazaar"
        ],
        "summary": "Item List",
        "description": "Get a list of available items in Bazaar.\n",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BazaarItemList"
                }
              }
            }
          },
          "404": {
            "description": "Data was not populated yet"
          }
        },
        "deprecated": false,
        "security": []
      }
    },
    "/v1/skyblock/bazaar/{itemId}/details": {
      "get": {
        "tags": [
          "SkyBlock Bazaar"
        ],
        "summary": "Item Details",
        "description": "Get the details of a Bazaar item.\n\nThis endpoint will return the top buy entries, top sell entries, buy volume and sell volume\n",
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "description": "Identifier of the item, see the items endpoint for list of available values.",
            "required": true,
            "deprecated": false,
            "allowEmptyValue": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BazaarItemInfo"
                }
              }
            }
          },
          "404": {
            "description": "Data was not populated yet"
          },
          "503": {
            "description": "Service temporarily unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "deprecated": false,
        "security": []
      }
    },
    "/v1/skyblock/profile/{profileId}": {
      "get": {
        "tags": [
          "SkyBlock"
        ],
        "summary": "SkyBlock Profile",
        "description": "Retrieves a SkyBlock profile.\n\n## Conditional Fields\nSome fields are only included if the profile owner has enabled them in their API settings.\n",
        "parameters": [
          {
            "name": "profileId",
            "in": "path",
            "description": "UUID of the SkyBlock profile (32 hex characters, no dashes)",
            "required": true,
            "deprecated": false,
            "allowEmptyValue": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Profile found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkyBlockProfile"
                }
              }
            }
          },
          "400": {
            "description": "Invalid profile ID format"
          },
          "404": {
            "description": "Profile not found"
          }
        },
        "deprecated": false,
        "security": []
      }
    },
    "/v1/skyblock/settings": {
      "get": {
        "tags": [
          "SkyBlock"
        ],
        "summary": "SkyBlock Settings",
        "description": "Retrieves a the global SkyBlock Settings.\n\nThese settings include the banner image queue for the SkyBlock Menu. Only the first non-expired image is served.\n",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkyBlockSettings"
                }
              }
            }
          },
          "404": {
            "description": "Settings were not populated yet."
          }
        },
        "deprecated": false,
        "security": []
      }
    }
  },
